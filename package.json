{
  "name": "@armoyu/core",
  "version": "1.1.34",
  "description": "Core business logic, models, and services for ARMOYU platforms.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "cd examples/console && npm run dev",
    "build:bundle": "esbuild src/index.ts --bundle --outfile=dist/armoyu-core.bundle.js --platform=browser --global-name=ArmoyuCore --minify",
    "build:watch": "tsc --watch",
    "test": "npx tsx tests/auth-guards.test.ts && npx tsx --env-file=.env tests/user-enrichment.test.ts && npx tsx --env-file=.env tests/news-enrichment.test.ts && npx tsx --env-file=.env tests/search-enrichment.test.ts && npx tsx --env-file=.env tests/event-enrichment.test.ts",
    "test:auth": "npx tsx --env-file=.env tests/services/auth.test.ts",
    "test:user": "npx tsx --env-file=.env tests/services/user.test.ts",
    "test:community": "npx tsx --env-file=.env tests/services/community.test.ts",
    "test:social": "npx tsx --env-file=.env tests/services/social.test.ts",
    "test:blog": "npx tsx --env-file=.env tests/services/blog.test.ts",
    "test:chat": "npx tsx --env-file=.env tests/services/chat.test.ts",
    "test:block": "npx tsx --env-file=.env tests/services/block.test.ts",
    "test:poll": "npx tsx --env-file=.env tests/services/poll.test.ts",
    "test:support": "npx tsx --env-file=.env tests/services/support.test.ts",
    "test:staff": "npx tsx --env-file=.env tests/services/staff.test.ts",
    "test:rule": "npx tsx --env-file=.env tests/services/rule.test.ts",
    "test:location": "npx tsx --env-file=.env tests/services/location.test.ts",
    "test:story": "npx tsx --env-file=.env tests/services/story.test.ts",
    "test:team": "npx tsx --env-file=.env tests/services/team.test.ts",
    "test:api": "npm run test:auth && npm run test:user && npm run test:community && npm run test:social && npm run test:blog && npm run test:chat && npm run test:block && npm run test:poll && npm run test:support && npm run test:staff && npm run test:rule && npm run test:location && npm run test:story && npm run test:team",
    "test:debug": "npx tsx --env-file=.env tests/debug-filtering.test.ts"
  },
  "dependencies": {
    "build": "^0.1.4",
    "run": "^1.5.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  }
}